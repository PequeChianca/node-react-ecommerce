# ============================================================
#  .env.example — copy this file to .env and fill in values
#  cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# PayPal
# Get your client ID from https://developer.paypal.com/
# Use the Sandbox client ID for testing, Live for production.
# ------------------------------------------------------------
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id

# ------------------------------------------------------------
# Azure Blob Storage (production only)
# In development mode this is overridden by docker.compose.dev.yml
# with the Azurite well-known dev key — you can leave this blank
# for local development.
#
# For a real Azure Storage Account, copy the connection string
# from: Azure Portal → Storage Account → Access keys
# ------------------------------------------------------------
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your_account>;AccountKey=<your_key>;EndpointSuffix=core.windows.net
