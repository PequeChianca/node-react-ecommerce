# ── Stage 1: build ────────────────────────────────────────────────────────────
FROM node:20-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .


# The package.json build script uses Windows "set" syntax; override with ENV.
# GENERATE_SOURCEMAP=false prevents .map files from being shipped to the browser.
ENV NODE_OPTIONS=--openssl-legacy-provider \
    GENERATE_SOURCEMAP=false
RUN npx react-scripts build

# ── Stage 2: serve ────────────────────────────────────────────────────────────
FROM nginx:alpine

COPY --from=build /app/build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
