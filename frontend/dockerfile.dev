FROM node:20-alpine

WORKDIR /app

ENV NODE_OPTIONS=--openssl-legacy-provider
# Required for file-change detection inside Docker volumes on Windows/macOS
ENV CHOKIDAR_USEPOLLING=true
ENV WATCHPACK_POLLING=true

# Install dependencies as part of the image so the anonymous /app/node_modules
# volume is seeded with the correct Linux binaries (not the Windows host ones).
COPY package*.json ./
RUN npm install

EXPOSE 3000
CMD ["sh", "-c", "npm start"]
